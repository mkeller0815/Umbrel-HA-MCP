#!/usr/bin/env bash
set -euo pipefail

APP_DIR="${APP_DATA_DIR:-$(readlink -f "$(dirname "${BASH_SOURCE[0]}")/..")}"
DATA_DIR="${APP_DIR}/data"
ENV_FILE="${DATA_DIR}/.env"

mkdir -p "${DATA_DIR}"
# mcpuser (UID 999) inside the server container needs write access to this
# directory to save feature_flags.json and other runtime files.
chown -R 999:999 "${DATA_DIR}" 2>/dev/null || true

# Write .env with the HA URL pre-filled from Umbrel's device domain.
# Preserves any existing HOMEASSISTANT_TOKEN the user already set.
if [[ ! -f "${ENV_FILE}" ]]; then
    cat > "${ENV_FILE}" <<EOF
# Home Assistant MCP Server configuration
# Edit this file to connect to your Home Assistant instance.

# URL is pre-filled for the Umbrel Home Assistant app (port 8123).
# Change this if your Home Assistant runs elsewhere.
HOMEASSISTANT_URL=http://${DEVICE_DOMAIN_NAME:-umbrel.local}:8123

# Paste your long-lived access token here.
# Get one from: Home Assistant → Profile → Long-Lived Access Tokens → Create Token
HOMEASSISTANT_TOKEN=
EOF
    echo "ha-mcp: created ${ENV_FILE} — open the app to configure your token."
fi

# Tailscale Serve — only runs if the Tailscale Umbrel app is present and the
# user has enabled the option in the setup UI (TAILSCALE_SERVE_ENABLED=true).
TAILSCALE_ENABLED=$(grep -s "^TAILSCALE_SERVE_ENABLED=" "${ENV_FILE}" | cut -d= -f2-)

if docker inspect tailscale_web_1 --format '{{.State.Running}}' 2>/dev/null | grep -q true; then
    # Use CertDomains — the top-level array always contains exactly the self hostname.
    # DNSName appears in every peer entry so grep on the full JSON is unreliable.
    TAILNET_HOST=$(docker exec tailscale_web_1 tailscale status --self --json 2>/dev/null \
        | grep -o '"CertDomains":\["[^"]*"' | grep -o '"[^"]*"$' | tr -d '"')

    if [[ -n "${TAILNET_HOST}" ]]; then
        if grep -q "^TAILSCALE_HOSTNAME=" "${ENV_FILE}" 2>/dev/null; then
            sed -i "s|^TAILSCALE_HOSTNAME=.*|TAILSCALE_HOSTNAME=${TAILNET_HOST}|" "${ENV_FILE}"
        else
            echo "TAILSCALE_HOSTNAME=${TAILNET_HOST}" >> "${ENV_FILE}"
        fi
    fi

    if [[ "${TAILSCALE_ENABLED}" == "true" ]]; then
        if docker exec tailscale_web_1 tailscale serve --bg http://localhost:8086 2>/dev/null; then
            echo "ha-mcp: Tailscale Serve enabled — https://${TAILNET_HOST}/mcp"
        else
            echo "ha-mcp: Tailscale Serve setup failed (non-fatal, LAN access still works)."
        fi
    else
        # User disabled the toggle — remove Serve config if it was previously set.
        docker exec tailscale_web_1 tailscale serve reset 2>/dev/null \
            && echo "ha-mcp: Tailscale Serve disabled." || true
    fi
else
    echo "ha-mcp: Tailscale app not running — skipping Tailscale Serve setup."
fi
